<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="AG-Claw"
    Manufacturer="AG064"
    Version="$(var.ProductVersion)"
    UpgradeCode="A002E425-E43E-49C7-90F0-723F9AD4C3C1"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of AG-Claw is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AG-Claw">
        <Component Id="AgClawExeComponent" Guid="8E295BDD-8F27-4660-BB35-76B8C1D180DD">
          <File Id="AgClawExe" Source="$(var.SourceExe)" Name="agclaw.exe" KeyPath="yes" />
          <Environment
            Id="AgClawPath"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="AG-Claw" Level="1">
      <ComponentRef Id="AgClawExeComponent" />
    </Feature>
  </Package>
</Wix>
