{
  "name": "ag-claw",
  "version": "0.1.0",
  "description": "Modular AI agent framework built on OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "jest --config jest.config.js",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "keywords": ["ai-agent", "openclaw", "modular", "chatbot", "automation"],
  "author": "AG064",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.3.4",
    "winston": "^3.11.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "node-cron": "^3.0.3",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "chokidar": "^3.5.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AG064/ag-claw.git"
  }
}
