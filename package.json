{
  "name": "argentum",
  "version": "0.0.5",
  "description": "Self-hosted modular AI agent framework with local-first setup and no subscriptions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "argentum": "bin/argentum.js"
  },
  "scripts": {
    "build": "tsc && tsc src/cli.ts --outDir dist --esModuleInterop --target ES2020 --module commonjs --skipLibCheck --resolveJsonModule",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js start",
    "onboard": "tsx src/cli.ts onboard",
    "cli": "node dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint src/ --max-warnings 999",
    "lint:fix": "eslint src/ --fix",
    "lint:watch": "esw src/ --ext .ts --watch --reset",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:all": "prettier --write \"**/*.{ts,js,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --coverage --coverage-reporters=text-summary --coverage-reporters=lcov --coverage-reporters=html",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js tests/unit --passWithNoTests",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js tests/integration --passWithNoTests",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js tests/e2e --passWithNoTests",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --ci --coverage --coverage-reporters=text-summary --coverage-reporters=lcov",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "build:prod": "tsc --noEmit && tsc",
    "clean": "rimraf dist .tsbuildinfo",
    "rebuild": "npm run clean && npm run build",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "package:win": "npm run desktop:build",
    "package:win:gui": "npm run desktop:build",
    "package:win:cli": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-release.ps1 -SkipMsi",
    "package:win:exe": "npm run package:win:cli",
    "desktop:dev": "cd src/desktop && tauri dev",
    "desktop:build": "cd src/desktop && tauri build",
    "predesktop:build": "npm run build && npm run build:desktop-sidecar",
    "build:desktop-sidecar": "node scripts/build-desktop-sidecar.js",
    "version:sync": "node scripts/sync-version.js",
    "version:check": "node scripts/sync-version.js --check",
    "prebuild": "npm run clean",
    "postinstall": "node scripts/postinstall-patch.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "config/**/*.yaml",
      "config/**/*.json",
      "docs/dashboard.html",
      "src/ui/desktop/**/*",
      "src/ui/dashboard/**/*",
      "dist/ui/**/*"
    ]
  },
  "keywords": [
    "ai-agent",
    "openclaw",
    "modular",
    "chatbot",
    "automation",
    "llm",
    "tool-loop",
    "self-hosted",
    "agent-framework"
  ],
  "author": "AG064",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@clack/prompts": "^1.2.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "jsep": "^1.4.0",
    "node-cron": "^4.2.1",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "pino-pretty": "^10.3.1",
    "sanitize-html": "^2.17.3",
    "ws": "^8.20.1",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-unicorn": "^50.0.1",
    "globals": "^17.4.0",
    "jest": "^30.4.1",
    "prettier": "^3.8.1",
    "rcedit": "4.0.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AG064/argentum.git"
  },
  "overrides": {
    "minimatch": "9.0.9",
    "undici": "~6.21.0",
    "cross-spawn": "^7.0.6",
    "glob": "^11.0.1",
    "brace-expansion": "^2.0.2",
    "picomatch": "^4.0.4",
    "anymatch": {
      "picomatch": "^2.3.1"
    },
    "ip-address": "^10.2.0",
    "postcss": "^8.5.10"
  }
}
