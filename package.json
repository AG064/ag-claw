{
  "name": "ag-claw",
  "version": "0.4.0",
  "description": "59 modular features. 8 channels. Self-hosted AI agent framework \u2014 zero subscriptions, total control.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agclaw": "bin/agclaw.js"
  },
  "scripts": {
    "build": "tsc && tsc src/cli.ts --outDir dist --esModuleInterop --target ES2020 --module commonjs --skipLibCheck --resolveJsonModule --ignoreConfig",
    "postbuild": "chmod +x bin/agclaw.js || true",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js start",
    "cli": "node dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint src/ --ext .ts --max-warnings 999",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "lint:watch": "esw src/ --ext .ts --watch --reset",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:all": "prettier --write \"**/*.{ts,js,json,md,yaml,yml}\" --ignore-path .prettierignore",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --coverage --coverage-reporters=text-summary --coverage-reporters=lcov --coverage-reporters=html",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js \"tests/unit\" --passWithNoTests",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js \"tests/integration\" --passWithNoTests",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js \"tests/e2e\" --passWithNoTests",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --ci --coverage --coverage-reporters=text-summary --coverage-reporters=lcov",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "build:prod": "tsc --noEmit && tsc",
    "clean": "rm -rf dist .tsbuildinfo",
    "rebuild": "npm run clean && npm run build",
    "docker:build": "docker compose -f docker/docker-compose.yml build",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "prebuild": "npm run clean",
    "postinstall": "node scripts/postinstall-patch.js"
  },
  "keywords": [
    "ai-agent",
    "openclaw",
    "modular",
    "chatbot",
    "automation",
    "llm",
    "tool-loop",
    "self-hosted",
    "agent-framework"
  ],
  "author": "AG064",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.42.0",
    "jsep": "^1.4.0",
    "mem0ai": "^2.4.5",
    "node-cron": "^3.0.3",
    "openai": "^4.80.0",
    "pino": "^10.3.1",
    "pino-pretty": "^10.3.1",
    "sanitize-html": "^2.17.2",
    "ws": "^8.16.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.38.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-unicorn": "^50.0.1",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AG064/ag-claw.git"
  },
  "overrides": {
    "minimatch": "9.0.9",
    "undici": "~6.21.0",
    "cross-spawn": "^7.0.6",
    "glob": "^11.0.1",
    "brace-expansion": "^3.0.2"
  }
}
