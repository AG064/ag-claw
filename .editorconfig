# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{ts,js,mjs,cjs}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2
max_line_length = off

[*.md]
trim_trailing_whitespace = false
max_line_length = off
indent_size = off

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[.eslintrc.js]
indent_size = 2
max_line_length = off
