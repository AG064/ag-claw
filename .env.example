# AG-Claw Environment Variables
# Copy to .env and fill in your keys

# Telegram Bot (required for Telegram channel)
AGCLAW_TELEGRAM_TOKEN=your_telegram_bot_token_here

# LLM Providers (at least one required)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# GEMINI_API_KEY=your_gemini_key_here

# Voice / TTS (optional)
# ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here

# Security (optional, for encrypted secrets)
# AGCLAW_MASTER_KEY=your_master_key_here

# Supabase (optional, for Supabase memory backend)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here

# Webhook server (optional)
# AGCLAW_WEBHOOK_PORT=3001

# NVIDIA API (free models)
NVIDIA_API_KEY=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
